# DaMelt — vzor env proměnných. Zkopíruj do .env.local a doplň hodnoty.
# Stejné proměnné nastav i ve Vercel projektu (Settings → Environment Variables).

# Supabase (vlastní projekt DaMelt — NE Swelt)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# Stripe (Fáze 1b — předobjednávka s platbou předem)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
